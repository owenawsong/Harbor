# Harbor Extension - Environment Variables
# Copy this file to .env and fill in your values for build-time configuration
# Note: These are only used during the build process and embedded in the extension

# Default API Keys (optional - users should set these in Settings UI)
# If set, these will be pre-filled in the Settings, but users can override them
# VITE_DEFAULT_ANTHROPIC_KEY=your-anthropic-key
# VITE_DEFAULT_OPENAI_KEY=your-openai-key
# VITE_DEFAULT_GOOGLE_KEY=your-google-api-key
# VITE_DEFAULT_OPENROUTER_KEY=your-openrouter-key

# Default Model Selection (optional)
# VITE_DEFAULT_PROVIDER=anthropic
# VITE_DEFAULT_MODEL=claude-opus-4-5

# Harbor Free Configuration (for custom NVIDIA NIM instance)
# VITE_HARBOR_FREE_API_KEY=your-nvidia-nim-key
# VITE_HARBOR_FREE_BASE_URL=https://integrate.api.nvidia.com/v1

# Build Environment
# VITE_VERSION=1.23.0
